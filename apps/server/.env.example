# MySQL connection string
DATABASE_URL="mysql://user:password@localhost:3306/secrets_manager"

# 32-byte master key (64 hex chars)
MASTER_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
MASTER_KEY_VERSION="v1"

# Web app origin for CORS and origin checks (set to your prod frontend URL in production)
APP_ORIGIN="http://localhost:5173"

# Session settings
SESSION_TTL_HOURS=168
COOKIE_SECURE=false
PORT=3001
