# Turso / libSQL connection
# Local file DB (recommended for development):
DATABASE_URL="file:./data/local.db"
# Turso cloud:
# DATABASE_URL="libsql://YOUR_DB-ORG.turso.io"
# DATABASE_AUTH_TOKEN="your-turso-auth-token"

# 32-byte master key (64 hex chars)
MASTER_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
MASTER_KEY_VERSION="v1"

# Web app origins for CORS, CSRF origin checks, and better-auth trustedOrigins.
# Comma-separated. Portless + plain local defaults; set to your prod frontend URL in production.
APP_ORIGIN="https://secrets.localhost,http://localhost:5173"

# Session settings
SESSION_TTL_HOURS=168
COOKIE_SECURE=false
# Used by `pnpm dev:server:plain`. Portless assigns a dynamic port for `pnpm dev:server`.
PORT=3001

# better-auth (dashboard/console login). Falls back to MASTER_KEY / PORTLESS_URL / localhost in dev.
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
BETTER_AUTH_URL="https://api.secrets.localhost"

# Passkeys (WebAuthn). RP ID must be the web app hostname (or parent domain).
# Defaults to hostname from APP_ORIGIN when unset.
# PASSKEY_RP_ID="secrets.localhost"
# PASSKEY_RP_NAME="Secrets"

# Logging
LOG_FORMAT=pretty
LOG_SINKS=console
LOG_REMOTE_ENABLED=false
# Reserved for future PostHog sink
# POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_API_KEY=phc_xxx

# Auth email delivery
AUTH_EMAIL_PROVIDER=noop
AUTH_EMAIL_FROM="auth@example.com"
AUTH_EMAIL_FROM_NAME="Secrets Auth"
# Required when AUTH_EMAIL_PROVIDER=resend
# RESEND_API_KEY="re_xxx"

# Runtime auth abuse protections
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_LOCK_MS=300000

# OAuth runtime settings
AUTH_RUNTIME_BASE_URL="https://api.secrets.localhost"
GOOGLE_OAUTH_SCOPES="openid,email,profile"
GITHUB_OAUTH_SCOPES="read:user,user:email"
