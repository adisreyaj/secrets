{
  "name": "server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sh -c \"tsc -w --preserveWatchOutput & while [ ! -f dist/index.js ]; do sleep 0.2; done; node --watch dist/index.js\"",
    "build:ts": "tsc -p tsconfig.json",
    "build": "pnpm run prisma:generate && pnpm run build:ts",
    "deploy": "pnpm run prisma:migrate:deploy && pnpm run build && pnpm run migrate:envelope",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "migrate:envelope": "node dist/server/scripts/migrateEnvelopeEncryption.js",
    "test": "vitest run",
    "lint": "oxlint",
    "format": "oxfmt . --write"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/type-provider-zod": "^1.0.0",
    "@prisma/adapter-mariadb": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "fastify": "^5.8.5",
    "pino-pretty": "^13.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "oxc": "^1.0.1",
    "oxlint": "^0.16.0",
    "prisma": "^7.3.0",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}