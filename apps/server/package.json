{
  "name": "server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sh -c \"tsc -w --preserveWatchOutput & while [ ! -f dist/index.js ]; do sleep 0.2; done; node --watch dist/index.js\"",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/adapter-mariadb": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "fastify": "^5.7.2"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "prisma": "^7.3.0",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
