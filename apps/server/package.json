{
  "name": "server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sh -c \"tsc -w --preserveWatchOutput & while [ ! -f dist/index.js ]; do sleep 0.2; done; node --watch dist/index.js\"",
    "build:ts": "tsc -p tsconfig.json",
    "build": "pnpm run build:ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "deploy": "pnpm run db:migrate && pnpm run build && pnpm run migrate:envelope",
    "start": "node dist/index.js",
    "migrate:envelope": "node dist/server/scripts/migrateEnvelopeEncryption.js",
    "test": "vitest run",
    "lint": "oxlint",
    "format": "oxfmt . --write"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/type-provider-zod": "^1.0.0",
    "@libsql/client": "^0.17.4",
    "@paralleldrive/cuid2": "^3.3.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.23",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "pino-pretty": "^13.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "drizzle-kit": "^0.31.10",
    "oxc": "^1.0.1",
    "oxlint": "^0.16.0",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
