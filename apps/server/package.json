{
  "name": "server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sh -c \"tsc -w --preserveWatchOutput & while [ ! -f dist/index.js ]; do sleep 0.2; done; node --watch dist/index.js\"",
    "build:ts": "tsc -p tsconfig.json",
    "build": "pnpm prisma:generate && pnpm prisma:migrate:deploy && pnpm run build:ts",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "test": "vitest run",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/adapter-mariadb": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "fastify": "^5.7.2"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "prisma": "^7.3.0",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}