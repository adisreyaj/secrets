generator client {
  provider = "prisma-client-js"
  engineType      = "client"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  DENIED
  CANCELED
}

enum ApprovalAction {
  CREATE
  UPDATE
  DELETE
  ROLLBACK
  COPY
  COPY_FROM
}

model User {
  id            String           @id @default(cuid())
  email         String           @unique
  passwordHash  String           @map("password_hash")
  name          String?
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  sessions      UserSession[]
  cliLoginSessions CliLoginSession[]
  memberships   ProjectMember[]
  createdTokens ApiToken[]       @relation("ApiTokenCreator")
  secretVersions SecretVersion[] @relation("SecretVersionCreator")
  auditLogs     AuditLog[]       @relation("AuditActor")
  projectInvites ProjectInvite[] @relation("ProjectInviteCreator")
  approvalRules ApprovalRule[]   @relation("ApprovalRuleCreator")
  approvalRequests ApprovalRequest[] @relation("ApprovalRequestRequester")
  approvalApprovals ApprovalRequest[] @relation("ApprovalRequestApprover")

  @@map("users")
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("user_sessions")
}

model CliLoginSession {
  id         String   @id @default(cuid())
  code       String   @unique
  token      String?  @map("token")
  userId     String?  @map("user_id")
  projectId  String?  @map("project_id")
  createdAt  DateTime @default(now()) @map("created_at")
  expiresAt  DateTime @map("expires_at")
  consumedAt DateTime? @map("consumed_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([code])
  @@index([expiresAt])
  @@map("cli_login_sessions")
}

model Project {
  id          String          @id @default(cuid())
  name        String
  slug        String?         @unique
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  members     ProjectMember[]
  environments Environment[]
  tokens      ApiToken[]
  audits      AuditLog[]
  invites     ProjectInvite[]
  approvalRules ApprovalRule[]
  approvalRequests ApprovalRequest[]

  @@map("projects")
}

model ProjectMember {
  id        String  @id @default(cuid())
  projectId String  @map("project_id")
  userId    String  @map("user_id")
  role      Role

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId])
  @@map("project_members")
}

model ProjectInvite {
  id         String       @id @default(cuid())
  projectId  String       @map("project_id")
  email      String
  role       Role
  status     InviteStatus @default(PENDING)
  tokenHash  String       @map("token_hash")
  createdBy  String       @map("created_by")
  createdAt  DateTime     @default(now()) @map("created_at")
  expiresAt  DateTime     @map("expires_at")
  acceptedAt DateTime?    @map("accepted_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User    @relation("ProjectInviteCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([email])
  @@index([tokenHash])
  @@index([status])
  @@map("project_invites")
}

model Environment {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  name      String
  slug      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  secrets Secret[]
  approvalRules ApprovalRule[]
  approvalRequests ApprovalRequest[]

  @@unique([projectId, name])
  @@unique([projectId, slug])
  @@map("environments")
}

model Secret {
  id            String          @id @default(cuid())
  environmentId String          @map("environment_id")
  key           String
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  deletedAt     DateTime?       @map("deleted_at")

  environment Environment    @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  versions    SecretVersion[]
  approvalRequests ApprovalRequest[]

  @@unique([environmentId, key])
  @@map("secrets")
}

model SecretVersion {
  id         String   @id @default(cuid())
  secretId   String   @map("secret_id")
  ciphertext Bytes
  iv         Bytes
  tag        Bytes
  keyVersion String   @map("key_version")
  createdBy  String?  @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")
  isActive   Boolean  @default(true) @map("is_active")

  secret  Secret @relation(fields: [secretId], references: [id], onDelete: Cascade)
  creator User?  @relation("SecretVersionCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([secretId])
  @@index([isActive])
  @@map("secret_versions")
}

model ApiToken {
  id         String   @id @default(cuid())
  projectId  String   @map("project_id")
  name       String
  tokenHash  String   @map("token_hash")
  createdBy  String   @map("created_by")
  readOnly   Boolean  @default(false) @map("read_only")
  createdAt  DateTime @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User    @relation("ApiTokenCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([tokenHash])
  @@map("api_tokens")
}

model AuditLog {
  id           String   @id @default(cuid())
  projectId    String   @map("project_id")
  actorUserId  String?  @map("actor_user_id")
  action       String
  resourceType String   @map("resource_type")
  resourceId   String?  @map("resource_id")
  metadataJson Json?    @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actor   User?   @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([actorUserId])
  @@map("audit_logs")
}

model ApprovalRule {
  id            String         @id @default(cuid())
  projectId     String         @map("project_id")
  name          String
  environmentId String?        @map("environment_id")
  keyPattern    String         @map("key_pattern")
  actionsJson   Json           @map("actions_json")
  isActive      Boolean        @default(true) @map("is_active")
  createdBy     String         @map("created_by")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment Environment? @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  creator     User        @relation("ApprovalRuleCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([environmentId])
  @@index([isActive])
  @@map("approval_rules")
}

model ApprovalRequest {
  id                  String         @id @default(cuid())
  projectId           String         @map("project_id")
  environmentId       String         @map("environment_id")
  secretId            String?        @map("secret_id")
  action              ApprovalAction
  status              ApprovalStatus @default(PENDING)
  requestedBy         String         @map("requested_by")
  approvedBy          String?        @map("approved_by")
  approvedAt          DateTime?      @map("approved_at")
  deniedAt            DateTime?      @map("denied_at")
  canceledAt          DateTime?      @map("canceled_at")
  key                 String
  payloadCiphertext   Bytes?         @map("payload_ciphertext")
  payloadIv           Bytes?         @map("payload_iv")
  payloadTag          Bytes?         @map("payload_tag")
  payloadKeyVersion   String?        @map("payload_key_version")
  targetEnvironmentId String?        @map("target_environment_id")
  expectedVersionId   String?        @map("expected_version_id")
  metadataJson        Json?          @map("metadata_json")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  secret      Secret?     @relation(fields: [secretId], references: [id], onDelete: Cascade)
  requester   User        @relation("ApprovalRequestRequester", fields: [requestedBy], references: [id], onDelete: Cascade)
  approver    User?       @relation("ApprovalRequestApprover", fields: [approvedBy], references: [id], onDelete: SetNull)

  @@index([projectId, status])
  @@index([environmentId, status])
  @@index([requestedBy, status])
  @@index([secretId, status])
  @@index([action])
  @@map("approval_requests")
}
