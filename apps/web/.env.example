# API base URL (used at build time by Vite).
# Leave empty for same-origin (e.g. when web and API are on the same host).
# Portless local: https://api.secrets.localhost
# Plain local (`pnpm dev:server:plain`): http://localhost:3001
# For production, set to your API URL when building the web app.
VITE_API_URL=https://api.secrets.localhost
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com
VITE_ERROR_TRACKING_PROVIDER=posthog
VITE_ERROR_TRACKING_DEBUG=false
