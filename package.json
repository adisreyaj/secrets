{
  "name": "secrets-manager",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20.19"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:server": "pnpm -C apps/server dev",
    "dev:web": "pnpm -C apps/web dev",
    "build:server": "pnpm -C apps/server build",
    "build:web": "pnpm -C apps/web build",
    "build:cli": "pnpm -C packages/cli build",
    "build:sdk": "pnpm -C packages/sdk build",
    "start:server": "pnpm -C apps/server start",
    "start:web": "pnpm -C apps/web start",
    "lint:web": "pnpm -C apps/web lint",
    "lint:server": "pnpm -C apps/server lint",
    "format:web": "pnpm -C apps/web format",
    "format:check:web": "pnpm -C apps/web format:check",
    "test:server": "pnpm -C apps/server test",
    "prisma:generate": "pnpm -C apps/server prisma:generate",
    "prisma:migrate": "pnpm -C apps/server prisma:migrate",
    "yalc:publish:sdk": "pnpm -C packages/sdk build && pnpm -C packages/sdk dlx yalc publish",
    "yalc:publish:cli": "pnpm -C packages/cli build && pnpm -C packages/cli dlx yalc publish",
    "yalc:publish:all": "pnpm yalc:publish:sdk && pnpm yalc:publish:cli",
    "yalc:push:sdk": "pnpm -C packages/sdk build && pnpm -C packages/sdk dlx yalc push",
    "yalc:push:cli": "pnpm -C packages/cli build && pnpm -C packages/cli dlx yalc push",
    "yalc:push:all": "pnpm yalc:push:sdk && pnpm yalc:push:cli"
  }
}
