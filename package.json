{
  "name": "secrets-manager",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20.19"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter server --filter web --parallel dev",
    "dev:server": "pnpm -C apps/server dev",
    "dev:web": "pnpm -C apps/web dev",
    "build:server": "pnpm -C apps/server build",
    "build:web": "pnpm -C apps/web build",
    "build:cli": "pnpm -C packages/cli build",
    "cli:dev:build": "pnpm -C packages/sdk build && pnpm -C packages/cli build",
    "cli:dev": "node packages/cli/dist/index.mjs",
    "cli:dev:watch": "pnpm --filter @secrets/sdk --filter @secrets/cli -r --parallel build --watch",
    "build:sdk": "pnpm -C packages/sdk build",
    "start:server": "pnpm -C apps/server start",
    "start:web": "pnpm -C apps/web start",
    "lint:web": "pnpm -C apps/web lint",
    "lint:server": "pnpm -C apps/server lint",
    "format:web": "pnpm -C apps/web format",
    "format:check:web": "pnpm -C apps/web format:check",
    "test:server": "pnpm -C apps/server test",
    "db:generate": "pnpm -C apps/server db:generate",
    "db:migrate": "pnpm -C apps/server db:migrate",
    "db:push": "pnpm -C apps/server db:push",
    "yalc:publish:sdk": "pnpm -C packages/sdk build && pnpm -C packages/sdk exec yalc publish --private",
    "yalc:publish:cli": "pnpm -C packages/cli build && pnpm -C packages/cli exec yalc publish --private",
    "yalc:publish:all": "pnpm yalc:publish:sdk && pnpm yalc:publish:cli",
    "yalc:push:sdk": "pnpm -C packages/sdk build && pnpm -C packages/sdk exec yalc push --private",
    "yalc:push:cli": "pnpm -C packages/cli build && pnpm -C packages/cli exec yalc push --private",
    "yalc:push:all": "pnpm yalc:push:sdk && pnpm yalc:push:cli"
  },
  "devDependencies": {
    "oxc": "^1.0.1",
    "oxlint": "^0.16.0",
    "yalc": "1.0.0-pre.53"
  }
}